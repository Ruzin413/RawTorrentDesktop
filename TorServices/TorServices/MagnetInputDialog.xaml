<Window x:Class="TorServices.MagnetInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Magnet Link" Height="260" Width="480"
        Background="White" Foreground="#1B2A4A" WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow"
        FontFamily="Segoe UI"
        Icon="Resources/app_icon.png">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Magnet URI" FontSize="12" Foreground="#6C757D" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtMagnetUri" Grid.Row="1" Height="32" Padding="8,0" Background="#F8F9FA" Foreground="#1B2A4A"
                 BorderBrush="#CED4DA" BorderThickness="1" VerticalContentAlignment="Center" FontSize="12" Margin="0,0,0,16"/>
        <TextBlock Grid.Row="2" Text="Download to" FontSize="12" Foreground="#6C757D" Margin="0,0,0,4"/>
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtOutputDir" Height="32" Padding="8,0" Background="#F8F9FA" Foreground="#1B2A4A"
                     BorderBrush="#CED4DA" BorderThickness="1" VerticalContentAlignment="Center" IsReadOnly="True" FontSize="12" Margin="0,0,8,0"/>
            <Button Grid.Column="1" Content="Browse" Click="BtnBrowse_Click" Padding="14,0" Height="32" FontSize="12"
                    Background="White" Foreground="#1B2A4A" BorderBrush="#CED4DA" BorderThickness="1" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E9ECEF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Click="BtnCancel_Click" Margin="0,0,8,0" Padding="18,7" FontSize="12"
                    Background="White" Foreground="#1B2A4A" BorderBrush="#CED4DA" BorderThickness="1" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E9ECEF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Add Magnet" Click="BtnOk_Click" Padding="18,7" FontSize="12"
                    Background="#0D6EFD" Foreground="White" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0B5ED7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="TorServices.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TorServices"
        Title="RawTorrent" Height="720" Width="1050"
        Background="#F5F7FA" Foreground="#1B2A4A" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Icon="Resources/app_icon.png">
    <Window.Resources>
        <!-- Converters -->
        <local:StatusBgConverter x:Key="StatusBgConverter"/>
        <local:StatusFgConverter x:Key="StatusFgConverter"/>
        <!-- Primary Blue Button -->
        <Style TargetType="Button" x:Key="ActionButtonStyle">
            <Setter Property="Background" Value="#0D6EFD"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0B5ED7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0A58CA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Outlined Secondary Button -->
        <Style TargetType="Button" x:Key="SecondaryButtonStyle">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1B2A4A"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E9ECEF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab Style -->
        <Style TargetType="RadioButton" x:Key="TabButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6C757D"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="0,8,0,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="Transparent" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0,0,0,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#0D6EFD"/>
                                <Setter Property="BorderBrush" Value="#0D6EFD"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#1B2A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Column Headers -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#6C757D"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#DEE2E6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="24,18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="Resources/app_icon.png" Width="24" Height="24" Margin="0,0,10,0"/>
                            <TextBlock Text="RawTorrent" FontSize="18" FontWeight="SemiBold" Foreground="#0D6EFD" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="＋ Add Torrent" Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,0" Click="BtnAddTorrent_Click"/>
                            <Button Content="＋ Add Magnet" Style="{StaticResource SecondaryButtonStyle}" Click="BtnAddMagnet_Click"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <RadioButton x:Name="TabActive" Content="Active" IsChecked="True" Style="{StaticResource TabButtonStyle}" Checked="Tab_Checked"/>
                        <RadioButton x:Name="TabHistory" Content="History" Style="{StaticResource TabButtonStyle}" Checked="Tab_Checked" Margin="24,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Table -->
            <ListView x:Name="TorrentListView" Grid.Row="1" Background="White" BorderThickness="0" Foreground="#1B2A4A"
                      ScrollViewer.HorizontalScrollBarVisibility="Hidden">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#F0F2F5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="12,10">
                                        <GridViewRowPresenter Content="{TemplateBinding Content}" Columns="{TemplateBinding GridView.ColumnCollection}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#EBF2FF"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#F8F9FA"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ContextMenu>
                    <ContextMenu Background="White" Foreground="#1B2A4A" Opened="ContextMenu_Opened">
                        <MenuItem x:Name="MenuToggle" Header="Pause" Click="MenuToggle_Click"/>
                        <MenuItem Header="Open Folder" Click="MenuOpenFolder_Click"/>
                        <Separator/>
                        <MenuItem Header="Remove" Click="MenuRemove_Click"/>
                        <MenuItem Header="Remove with Data" Click="MenuRemoveData_Click" Foreground="#DC3545"/>
                    </ContextMenu>
                </ListView.ContextMenu>

                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="NAME" Width="340" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn x:Name="ColSize" Header="SIZE" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FormattedSize}" Foreground="#6C757D" FontSize="12"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="PROGRESS" Width="210">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center" Margin="0,2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding Progress, StringFormat={}{0:0.0}%}" 
                                                   Foreground="#0D6EFD" FontSize="10" FontWeight="SemiBold" 
                                                   HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                        <ProgressBar Grid.Row="1" Value="{Binding Progress, Mode=OneWay}" 
                                                     Maximum="100" Height="8" Background="#E9ECEF" 
                                                     Foreground="#198754" BorderThickness="0"/>
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="STATUS" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Status, Converter={StaticResource StatusBgConverter}}" CornerRadius="3" Padding="8,3">
                                        <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{Binding Status, Converter={StaticResource StatusFgConverter}}"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn x:Name="ColPeers" Header="PEERS" Width="55">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ActivePeers}" Foreground="#6C757D" FontSize="12"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="" Width="40">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="📂" ToolTip="Open Folder" Background="Transparent" BorderThickness="0" Foreground="#6C757D" FontSize="14" Cursor="Hand" Tag="{Binding}" Click="BtnRowOpenFolder_Click" Padding="0"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="12,8">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="Made by Rujin Manandhar" FontSize="11" FontWeight="SemiBold" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontSize="10" Foreground="#6C757D">
                            <Hyperlink NavigateUri="mailto:rzmdr413@gmail.com" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#0D6EFD" TextDecorations="None">rzmdr413@gmail.com</Hyperlink>
                            <Run Text=" | "/>
                            <Hyperlink NavigateUri="https://github.com/Ruzin413" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#0D6EFD" TextDecorations="None">Github</Hyperlink>
                            <Run Text=" | "/>
                            <Hyperlink NavigateUri="https://www.linkedin.com/in/ruzin-mdr-393bb9380/" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#0D6EFD" TextDecorations="None">LinkedIn</Hyperlink>
                            <Run Text=" | Kathmandu"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
